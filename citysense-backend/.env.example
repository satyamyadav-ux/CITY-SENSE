# ===========================================
# CITY SENSE BACKEND - ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env and fill in your real values
# NEVER commit the actual .env file to git

# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# MongoDB Atlas (or local MongoDB)
# Get free cluster at: https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/citysense?retryWrites=true&w=majority

# JWT Auth
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_DAYS=7

# OpenWeatherMap API (get free key at https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Rate Limiting
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX_REQUESTS=200

# File Uploads (community report photos)
MAX_UPLOAD_SIZE_MB=5
UPLOAD_DIR=uploads
